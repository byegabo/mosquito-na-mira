generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Denuncia {
  id            String   @id @default(uuid())
  protocolo     String   @unique
  status        String   @default("Em Análise")
  latitude      Float
  longitude     Float
  endereco      String
  fotoUrl       String?  
  dataCriacao   DateTime @default(now())
}

model PostoSaude {
  id        Int      @id @default(autoincrement())
  nome      String
  endereco  String
  horario   String
  telefone  String
  tipo      String
  cor       String
}